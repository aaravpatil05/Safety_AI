<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="Emergency Contacts"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Add up to 3 numbers to receive instant SOS SMS alerts with your live location."
        android:textColor="#3D3B56"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilContact1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:prefixText="+91 "
        app:layout_constraintTop_toBottomOf="@id/tvSub">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etContact1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contact 1"
            android:maxLength="10"
            android:inputType="phone" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilContact2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:prefixText="+91 "
        app:layout_constraintTop_toBottomOf="@id/tilContact1">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etContact2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contact 2"
            android:maxLength="10"
            android:inputType="phone" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilContact3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:prefixText="+91 "
        app:layout_constraintTop_toBottomOf="@id/tilContact2">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etContact3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contact 3"
            android:maxLength="10"
            android:inputType="phone" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveContacts"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:text="Save Contacts"
        android:textColor="?attr/colorSurface"
        android:textSize="18sp"
        app:backgroundTint="@color/header_red"
        app:cornerRadius="80dp"
        app:layout_constraintTop_toBottomOf="@id/tilContact3" />

</androidx.constraintlayout.widget.ConstraintLayout>
