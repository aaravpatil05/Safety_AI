<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/header_red"
        android:gravity="bottom|center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Features Menu Button -->
        <ImageView
            android:id="@+id/btnHomeFeatures"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_menu_features"
            app:tint="@color/bg_light" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="HOME"
            android:textColor="@color/bg_light"
            android:textSize="32sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnHomeSettings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_settings_outline"
                app:tint="@color/bg_light" />

            <ImageView
                android:id="@+id/btnHomeNotifications"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_bell_outline"
                app:tint="@color/bg_light" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="Status: You are Safe 🟢"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <FrameLayout
        android:id="@+id/btnSos"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginTop="32dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus">

        <!-- Unified Gradient Glow Background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/sos_new_glow" />

        <!-- SOS Core Text -->
        <TextView
            android:id="@+id/tvSosText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="SOS"
            android:textColor="@color/bg_light"
            android:textSize="58sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/aiPill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnSos">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Monitoring : "
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ON"
            android:textColor="#4CAF50"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomActionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/aiPill">

        <TextView
            android:id="@+id/btnShareLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/btn_bg"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="Share Location"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <View
            android:layout_width="24dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/btnCallEmergency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/btn_bg"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="📞 Call Emergency"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- LIVE SOS TRACKER UI (Hidden by default) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/trackerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="24dp"
        android:visibility="gone"
        app:cardBackgroundColor="#CC111111"
        app:strokeColor="#77F44336"
        app:strokeWidth="1dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnSos">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                android:text="LIVE EMERGENCY STATUS"
                android:textColor="#F44336"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView android:id="@+id/trStep1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏳ Acquiring precise GPS coordinates..." android:textColor="#B0BEC5" android:textSize="13sp" android:layout_marginBottom="12dp"/>
            <TextView android:id="@+id/trStep2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏳ Alerting Emergency Contacts..." android:textColor="#B0BEC5" android:textSize="13sp" android:layout_marginBottom="12dp"/>
            <TextView android:id="@+id/trStep3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏳ Transmitting coordinates to 112..." android:textColor="#B0BEC5" android:textSize="13sp" android:layout_marginBottom="12dp"/>
            <TextView android:id="@+id/trStep4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏳ Securely recording audio evidence..." android:textColor="#B0BEC5" android:textSize="13sp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
